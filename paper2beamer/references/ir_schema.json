{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papertalk-ir-skills/paper2beamer/ir_schema.json",
  "title": "paper2beamer IR",
  "description": "JSON-Schema mirror of the accumulative IR. The enforced contract is scripts/ir_common.py::validate_ir; this file is for editors and external tooling. tests/test_schema_consistency.py asserts the enums here match ir_common.",
  "type": "object",
  "required": ["meta", "paper", "figures"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema", "ir_version", "source_pdf", "produced_by_pass"],
      "properties": {
        "schema": { "const": "1.0" },
        "ir_version": { "type": "string", "pattern": "^v[0-9]+$" },
        "source_pdf": { "type": "string" },
        "produced_by_pass": { "type": "string" }
      }
    },
    "intent": {
      "type": "object",
      "required": ["occasion", "duration_min", "language"],
      "properties": {
        "occasion": { "type": "string" },
        "duration_min": { "type": "number", "exclusiveMinimum": 0 },
        "audience": { "type": "string" },
        "emphasis": { "type": "array", "items": { "type": "string" } },
        "language": { "enum": ["en", "zh", "bilingual"] },
        "depth": { "enum": ["overview", "balanced", "deep-dive"] },
        "domain_ref": { "type": "string" }
      }
    },
    "paper": {
      "type": "object",
      "required": ["title", "sections"],
      "properties": {
        "title": { "type": "string" },
        "authors": { "type": "array", "items": { "type": "string" } },
        "venue": { "type": "string" },
        "abstract": { "type": "string" },
        "sections": { "type": "array", "items": { "$ref": "#/$defs/section" } },
        "references": { "type": "array" }
      }
    },
    "figures": { "type": "array", "items": { "$ref": "#/$defs/figure" } },
    "claims": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
    "story": { "type": "array", "items": { "$ref": "#/$defs/beat" } },
    "slides": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/slide" } }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "text"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "level": { "type": "integer" },
        "text": { "type": "string" }
      }
    },
    "figure": {
      "type": "object",
      "required": ["id", "kind", "path"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["figure", "table", "equation"] },
        "page": { "type": ["integer", "null"] },
        "path": { "type": "string" },
        "caption": { "type": "string" },
        "referenced_in": { "type": "array", "items": { "type": "string" } }
      }
    },
    "claim": {
      "type": "object",
      "required": ["id", "type", "statement", "salience"],
      "properties": {
        "id": { "type": "string" },
        "section": { "type": ["string", "null"] },
        "type": { "enum": ["problem", "method", "result", "contribution", "limitation", "background"] },
        "statement": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "figure_refs": { "type": "array", "items": { "type": "string" } },
        "salience": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "beat": {
      "type": "object",
      "required": ["id", "role", "headline"],
      "properties": {
        "id": { "type": "string" },
        "role": { "enum": ["hook", "problem", "gap", "idea", "method", "result", "takeaway", "closing"] },
        "headline": { "type": "string" },
        "claim_refs": { "type": "array", "items": { "type": "string" } },
        "figures": { "type": "array", "items": { "$ref": "#/$defs/beat_figure" } },
        "est_minutes": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "beat_figure": {
      "type": "object",
      "required": ["figure_id"],
      "properties": {
        "figure_id": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "slide": {
      "type": "object",
      "required": ["frame_type"],
      "properties": {
        "frame_type": { "enum": ["titleframe", "frame", "statementframe", "thanksframe"] },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "headline": { "type": "string" },
        "subtitle": { "type": "string" },
        "story_ref": { "type": "string" },
        "density_hint": { "enum": ["normal", "dense"] },
        "notes": { "type": "string" },
        "body": { "type": "array", "items": { "$ref": "#/$defs/body_item" } }
      },
      "allOf": [
        {
          "if": { "properties": { "frame_type": { "const": "frame" } } },
          "then": { "required": ["title"] }
        },
        {
          "if": { "properties": { "frame_type": { "const": "statementframe" } } },
          "then": { "required": ["text"] }
        }
      ]
    },
    "body_item": {
      "type": "object",
      "oneOf": [
        {
          "required": ["block"],
          "properties": {
            "block": { "enum": ["block", "alertblock", "exampleblock", "itemize", "enumerate"] },
            "title": { "type": "string" },
            "text": { "type": "string" },
            "items": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "required": ["figure"],
          "properties": {
            "figure": { "type": "string" },
            "caption": { "type": "string" },
            "width": { "type": "string" }
          }
        }
      ]
    }
  }
}
