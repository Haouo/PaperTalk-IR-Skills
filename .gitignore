# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
*.egg-info/

# LaTeX build artifacts
*.aux
*.log
*.nav
*.out
*.snm
*.toc
*.fls
*.fdb_latexmk
*.xdv
*.synctex.gz
*.build.out

# Generated decks / build dirs (the IR + figures are inputs; PDFs are outputs)
build/
*.pdf

# Exception: the committed AIAYN sample deck (a reference output of the harness).
# AIAYN grants reuse of its figures for scholarly works; this is our own deck.
!eval/sample-output/**/*.pdf

# Keep the golden fixture and committed sample figures despite the rules above
!paper2beamer/tests/fixtures/**/figures/*.png
# Keep eval golden-IR figures (committed input fixtures, not generated output)
!eval/fixtures/**/figures/*.png
!eval/tests/fixtures/**/figures/*.png
# Test-fixture LaTeX logs are tracked inputs, despite the *.log rule above
!paper2beamer/tests/fixtures/*.log
# Eval grader test fixtures include a sample main.log input
!eval/tests/fixtures/**/*.log

# Runtime working dirs (generated per paper / per theme). The SHIPPED ISA lives
# at paper2beamer/isa/ and stays tracked; only the root-level isa/ is runtime.
/slides/
/isa/

# OS / editor
.DS_Store
*.swp

# Eval harness run artifacts (regenerated; not source)
eval/runs/
eval/report.md
