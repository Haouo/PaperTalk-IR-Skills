% =============================================================================
% beamerthemeSidebar.sty - a left-sidebar 16:9 Beamer theme, deliberately
% divergent from Simple (sidebar navigation + rounded blocks + teal palette).
%
% Copyright (c) 2026 Chun-Hao Chang (Haouo). MIT License.
%
% Purpose in paper2beamer: a SECOND theme with a divergent capability profile,
% so theme-swap invariance (RQ4) is a real test. It provides Base + Zsem +
% Theorems + Columns + OverflowGuard, and deliberately does NOT provide the
% SpecialFrames extension (no \titleframe/\statementframe/\thanksframe), so a
% deck using those must be degraded to Base equivalents on swap.
%
% --- OPTIONS (\usetheme[...]{Sidebar}) ---------------------------------------
%   density=normal|dense    tighter type for content-heavy decks
%   overflowguard=on|off    hard-error when a frame body reaches the footer
% =============================================================================
\ProvidesPackage{beamerthemeSidebar}[2026/06/15 v1.0 Sidebar standalone Beamer theme]

\mode<presentation>

% ---------- options ----------
\RequirePackage{etoolbox}
\def\sidebar@density{normal}
\def\sidebar@guard{off}
\DeclareOptionBeamer{density}{\def\sidebar@density{#1}}
\DeclareOptionBeamer{overflowguard}{\def\sidebar@guard{#1}}
\ProcessOptionsBeamer

\newcommand{\sidebar@oneof}[3]{%
  \def\sidebar@ok{0}%
  \forcsvlist{\sidebar@checkval#1}{#2}%
  \ifdefstring{\sidebar@ok}{0}{%
    \PackageError{beamerthemeSidebar}{Unknown #3 value `#1'; allowed: #2}{}%
  }{}%
}
\newcommand{\sidebar@checkval}[2]{\ifdefstring{#1}{#2}{\def\sidebar@ok{1}}{}}
\sidebar@oneof{\sidebar@density}{normal,dense}{density}
\sidebar@oneof{\sidebar@guard}{on,off}{overflowguard}

% ---------- fonts (engine-aware, graceful; Latin-safe fallback) ----------
\RequirePackage{iftex}
\ifboolexpr{ bool {xetex} or bool {luatex} }{%
  \RequirePackage{fontspec}%
  \IfFontExistsTF{TeX Gyre Heros}{\setsansfont{TeX Gyre Heros}}{}%
}{%
  \RequirePackage[T1]{fontenc}%
  \RequirePackage{lmodern}%
}

% ---------- built-in sidebar layout + rounded blocks (divergent look) -------
\useoutertheme[width=22mm,height=0pt]{sidebar}
\useinnertheme{rounded}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{caption label separator}[colon]

% ---------- colors ----------
\providecolor{sidebarBand}{RGB}{38,50,64}      % dark slate sidebar
\providecolor{sidebarAccent}{RGB}{0,131,143}   % teal accent
\providecolor{sidebarAlert}{RGB}{158,108,24}   % caveat (gold)
\providecolor{sidebarExample}{RGB}{35,132,104} % example (green)
\providecolor{sidebarDark}{RGB}{31,36,42}
\providecolor{sidebarGray}{RGB}{102,108,116}

\setbeamercolor{normal text}{fg=sidebarDark,bg=white}
\setbeamercolor{structure}{fg=sidebarAccent}
\setbeamercolor{alerted text}{fg=sidebarAlert}
\setbeamercolor{example text}{fg=sidebarExample}
\setbeamercolor{frametitle}{fg=sidebarDark,bg=white}
% sidebar canvas + its navigation
\setbeamercolor{palette sidebar primary}{fg=white}
\setbeamercolor{palette sidebar secondary}{fg=white!70}
\setbeamercolor{sidebar}{bg=sidebarBand}
\setbeamercolor{section in sidebar}{fg=white}
\setbeamercolor{section in sidebar shaded}{fg=white!45}
\setbeamercolor{subsection in sidebar}{fg=white!85}
\setbeamercolor{subsection in sidebar shaded}{fg=white!40}
\setbeamercolor{title in sidebar}{fg=white}
\setbeamercolor{author in sidebar}{fg=white!70}
% rounded blocks: filled tinted headers (different from Simple's left rule)
\setbeamercolor{block title}{fg=white,bg=sidebarAccent}
\setbeamercolor{block body}{fg=sidebarDark,bg=sidebarAccent!8}
\setbeamercolor{block title alerted}{fg=white,bg=sidebarAlert}
\setbeamercolor{block body alerted}{fg=sidebarDark,bg=sidebarAlert!10}
\setbeamercolor{block title example}{fg=white,bg=sidebarExample}
\setbeamercolor{block body example}{fg=sidebarDark,bg=sidebarExample!9}

\setbeamerfont{title}{series=\bfseries,size=\LARGE}
\setbeamerfont{frametitle}{series=\bfseries,size=\large}
\setbeamerfont{block title}{series=\bfseries}

\ifdefstring{\sidebar@density}{dense}{%
  \setbeamerfont{frametitle}{series=\bfseries,size=\normalsize}%
  \setbeamerfont{block title}{series=\bfseries,size=\small}%
  \setbeamerfont{block body}{size=\small}%
}{}

% ---------- opt-in vertical overflow guard (identical mechanism to Simple) ----
\ifdefstring{\sidebar@guard}{on}{%
  \newlength{\sidebar@bodyht}%
  \newcommand{\sidebar@checkoverflow}{%
    \ifbeamer@plainframe\else
      \ifbeamer@autobreak\else
        \setlength{\sidebar@bodyht}{\ht\beamer@framebox}%
        \ifdim\sidebar@bodyht>\dimexpr\textheight+0.1pt\relax
          \PackageError{beamerthemeSidebar}{Frame body overflows the safe area on
            slide \the\numexpr\insertframenumber\relax: content is
            \the\sidebar@bodyht\space tall but only \the\textheight\space fits}{%
            Shorten or split the slide, use density=dense, or
            \string\begin{frame}[allowframebreaks].}%
        \fi
      \fi
    \fi}%
  \pretocmd{\beamer@autobreakframebox}{\sidebar@checkoverflow}{}{%
    \PackageWarning{beamerthemeSidebar}{Could not install the overflow guard
      (beamer internals changed); slides may silently overflow the footer.}}%
}{}

\mode<all>
